{
  "name": "chopsticks",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Native TUI coding-agent runtime: host agents' original terminal experiences with managed lifecycle, observation, and guarded control",
  "license": "MIT",
  "author": "James Yong",
  "scripts": {
    "postinstall": "node scripts/fix-node-pty-perms.mjs",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm typecheck && pnpm -r test",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": ["node-pty", "electron", "esbuild"]
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
