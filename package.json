{
  "name": "chopsticks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Native TUI coding-agent runtime: host agents' original terminal experiences with managed lifecycle, observation, and guarded control",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesyong-42/chopsticks.git"
  },
  "homepage": "https://github.com/jamesyong-42/chopsticks#readme",
  "bugs": {
    "url": "https://github.com/jamesyong-42/chopsticks/issues"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm typecheck && pnpm -r test",
    "pack:check": "pnpm build && pnpm -r --filter './packages/**' pack --dry-run",
    "format:check": "prettier --check 'packages/*/src/**/*.{ts,tsx}'",
    "format": "prettier --write 'packages/*/src/**/*.{ts,tsx}'"
  },
  "engines": {
    "node": ">=20"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "esbuild"
    ],
    "overrides": {
      "@vibecook/ghosttea": "link:../../electron-ghostty/packages/terminal-client",
      "@vibecook/ghosttea-electron": "link:../../electron-ghostty/packages/terminal-electron",
      "@vibecook/ghosttea-frame": "link:../../electron-ghostty/packages/terminal-frame",
      "@vibecook/ghosttea-protocol": "link:../../electron-ghostty/packages/terminal-protocol",
      "@vibecook/ghosttea-react": "link:../../electron-ghostty/packages/terminal-react"
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "prettier": "^3.3.0",
    "typescript": "^5.5.0",
    "vitest": "^3.0.0"
  }
}
