{
  "name": "workbench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Electron dev workbench for chopsticks: Ghostty-fashion chrome (TerminalSurface/restty), pty-host, agent panels.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./dist/main.cjs",
  "scripts": {
    "bundle": "node build.mjs",
    "start": "node build.mjs && electron .",
    "smoke": "node build.mjs && electron . --smoke",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.0",
    "@vibecook/avocado-sdk": "file:../../../avocado/packages/sdk",
    "@vibecook/chopsticks-adapter-acp": "workspace:*",
    "@vibecook/chopsticks-adapter-claude": "workspace:*",
    "@vibecook/chopsticks-adapter-codex": "workspace:*",
    "@vibecook/chopsticks-core": "workspace:*",
    "@vibecook/chopsticks-node": "workspace:*",
    "@vibecook/chopsticks-record": "workspace:*",
    "@vibecook/chopsticks-testing": "workspace:*",
    "@vibecook/chopsticks-workspaces": "workspace:*",
    "@xterm/addon-fit": "^0.10.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "restty": "^0.2.0",
    "xterm": "^5.3.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
