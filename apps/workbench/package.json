{
  "name": "workbench",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Ghosttea desktop workbench for observing and controlling Chopsticks agents.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./dist/main.cjs",
  "scripts": {
    "prebundle": "npm --prefix ../../../../electron-ghostty run build:sdk",
    "bundle": "node build.mjs",
    "start": "pnpm bundle && electron .",
    "smoke": "pnpm bundle && electron . --smoke",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@parcel/watcher": "^2.5.0",
    "@vibecook/chopsticks-core": "workspace:*",
    "@vibecook/chopsticks-record": "workspace:*",
    "@vibecook/chopsticks-runtime": "workspace:*",
    "@vibecook/chopsticks-workspaces": "workspace:*",
    "@vibecook/ghosttea": "file:../../../../electron-ghostty/packages/terminal-client",
    "@vibecook/ghosttea-electron": "file:../../../../electron-ghostty/packages/terminal-electron",
    "@vibecook/ghosttea-frame": "file:../../../../electron-ghostty/packages/terminal-frame",
    "@vibecook/ghosttea-protocol": "file:../../../../electron-ghostty/packages/terminal-protocol",
    "@vibecook/ghosttea-react": "file:../../../../electron-ghostty/packages/terminal-react",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "electron": "^43.1.0",
    "esbuild": "^0.24.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.0"
  }
}
