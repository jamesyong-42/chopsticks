{
  "name": "@vibecook/chopsticks-record",
  "version": "0.1.3",
  "type": "module",
  "description": "Own-action record: the append-only JSONL log of what the chopsticks runtime itself did (injections, workspace finals, exits, policy conflicts).",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesyong-42/chopsticks.git",
    "directory": "packages/record"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  }
}
