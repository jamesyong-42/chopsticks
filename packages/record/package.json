{
  "name": "@vibecook/chopsticks-record",
  "version": "0.0.0",
  "type": "module",
  "description": "Own-action record: the append-only JSONL log of what the chopsticks runtime itself did (injections, workspace finals, exits, policy conflicts).",
  "license": "MIT",
  "author": "James Yong",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  }
}
