{
  "name": "@vibecook/chopsticks-runtime",
  "version": "0.1.1",
  "type": "module",
  "description": "Unified Chopsticks agent runtime: provider registry, session lifecycle, workspace isolation, events, and action recording.",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesyong-42/chopsticks.git",
    "directory": "packages/runtime"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@vibecook/chopsticks-adapter-claude": "workspace:*",
    "@vibecook/chopsticks-adapter-codex": "workspace:*",
    "@vibecook/chopsticks-adapter-grok": "workspace:*",
    "@vibecook/chopsticks-core": "workspace:*",
    "@vibecook/chopsticks-record": "workspace:*",
    "@vibecook/chopsticks-workspaces": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
