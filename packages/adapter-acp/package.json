{
  "name": "@vibecook/chopsticks-adapter-acp",
  "version": "0.1.3",
  "type": "module",
  "description": "Generic Agent Client Protocol (ACP) adapter: transport connectors, session/update normalization, lifecycle, permissions, and deterministic prompt injection.",
  "license": "MIT",
  "author": "James Yong",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jamesyong-42/chopsticks.git",
    "directory": "packages/adapter-acp"
  },
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true,
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "pnpm clean && tsc -p tsconfig.build.json",
    "prepack": "pnpm build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "1.2.1",
    "@vibecook/chopsticks-core": "workspace:*"
  },
  "devDependencies": {
    "@vibecook/chopsticks-testing": "workspace:*"
  }
}
