{
  "name": "@vibecook/chopsticks-node",
  "version": "0.0.0",
  "type": "module",
  "description": "Node runtime for chopsticks: PTY transport, process-tree control, ordered terminal distribution with sink policies.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibecook/chopsticks-core": "workspace:*",
    "@xterm/addon-serialize": "^0.13.0",
    "@xterm/headless": "^5.5.0",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@vibecook/chopsticks-testing": "workspace:*"
  }
}
