{
  "name": "@vibecook/chopsticks-adapter-grok",
  "version": "0.0.0",
  "type": "module",
  "description": "Grok adapter for Chopsticks: native TUI, shared leader lifecycle, and ACP control composition.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibecook/chopsticks-adapter-acp": "workspace:*",
    "@vibecook/chopsticks-core": "workspace:*"
  }
}
