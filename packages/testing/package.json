{
  "name": "@vibecook/chopsticks-testing",
  "version": "0.0.0",
  "type": "module",
  "description": "Test harness for the chopsticks runtime: fake terminal agent, captured hook fixtures, synthetic hook payloads.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./conformance": "./src/conformance.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      },
      "./conformance": {
        "types": "./dist/conformance.d.ts",
        "import": "./dist/conformance.js"
      }
    }
  },
  "files": ["dist", "bin", "fixtures"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibecook/chopsticks-core": "workspace:*"
  },
  "devDependencies": {
    "vitest": "^3.0.0"
  }
}
