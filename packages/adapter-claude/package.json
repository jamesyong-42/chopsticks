{
  "name": "@vibecook/chopsticks-adapter-claude",
  "version": "0.0.0",
  "type": "module",
  "description": "Claude Code native adapter: hook registry, loopback hook bridge, event normalizer, settings generation.",
  "license": "MIT",
  "author": "James Yong",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.js",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.js"
      }
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@vibecook/chopsticks-core": "workspace:*",
    "@vibecook/spaghetti-sdk": "^0.5.16"
  },
  "devDependencies": {
    "@vibecook/chopsticks-testing": "workspace:*"
  }
}
